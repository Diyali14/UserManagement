# Stage 1: Build the Spring Boot app
FROM maven:3.9.2-eclipse-temurin-20 AS build
WORKDIR /app
COPY springboot-usermanagement/pom.xml .
COPY springboot-usermanagement/src ./src
RUN mvn clean package -DskipTests

# Stage 2: Run the app
FROM eclipse-temurin:20-jre
WORKDIR /app
COPY --from=build /app/target/*.jar app.jar

# Copy frontend into resources so Spring Boot can serve it
COPY springbootusermanagement_Frontend /frontend
# Optional: if you want Spring Boot to serve frontend
# Move frontend files into /app/resources/static if needed

COPY springbootusermanagement_Frontend /app/springboot-usermanagement/src/main/resources/static

# Expose port
EXPOSE 8080

# Run the Spring Boot app
ENTRYPOINT ["java","-jar","app.jar"]

